generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String?
  fullName       String
  role           String
  avatarUrl      String?
  firstLoginAt   DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  discussions    Discussion[]
  enrollments    Enrollment[]
  gradedAttempts FinalQuizGrade[] @relation("Grader")
  managedModule  Module?          @relation("ModuleManager")
  quizAttempts   QuizAttempt[]
  reviews        Review[]
}

model PasswordResetOtp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Module {
  id                  String        @id @default(cuid())
  title               String
  subtitle            String?
  description         String
  imageUrl            String?
  teaserVideoUrl      String?
  level               String?
  sharePointFolderUrl String?
  authorName          String
  authorBio           String?
  authorAvatarUrl     String?
  managerId           String?       @unique
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  prerequisites       String?
  moduleType          String?
  learningObjectives  String?
  certificates        Certificate[]
  chapters            Chapter[]
  courses             Course[]
  discussions         Discussion[]
  enrollments         Enrollment[]
  manager             User?         @relation("ModuleManager", fields: [managerId], references: [id])
  quizzes             Quiz[]
  reviews             Review[]
}

model Course {
  id          String    @id @default(cuid())
  moduleId    String
  title       String
  description String?
  order       Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chapters    Chapter[]
  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Chapter {
  id          String        @id @default(cuid())
  moduleId    String
  title       String
  order       Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  courseId    String?
  description String?
  course      Course?       @relation(fields: [courseId], references: [id])
  module      Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  items       ChapterItem[]
  quizzes     Quiz[]
}

model ChapterItem {
  id              String               @id @default(cuid())
  chapterId       String
  type            String
  order           Int
  title           String
  durationMinutes Int?
  videoUrl        String?
  documentLabel   String?
  documentUrl     String?
  quizId          String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  chapter         Chapter              @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  quiz            Quiz?                @relation(fields: [quizId], references: [id])
  progress        EnrollmentProgress[]
}

model Quiz {
  id             String         @id @default(cuid())
  moduleId       String
  chapterId      String?
  title          String
  isFinal        Boolean        @default(false)
  minScoreToPass Int            @default(70)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  items          ChapterItem[]
  chapter        Chapter?       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  module         Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attempts       QuizAttempt[]
  questions      QuizQuestion[]
}

model QuizQuestion {
  id           String   @id @default(cuid())
  quizId       String
  questionText String
  options      Json
  correctIndex Int
  correctIndexes Int[]  @default([])
  points       Int      @default(1)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                  String               @id @default(cuid())
  userId              String
  moduleId            String
  enrolledAt          DateTime             @default(now())
  lastViewedChapterId String?
  lastViewedItemId    String?
  progressPercent     Int                  @default(0)
  completedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  certificate         Certificate?
  module              Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress            EnrollmentProgress[]
  finalGrade          FinalQuizGrade[]
  attempts            QuizAttempt[]
}

model EnrollmentProgress {
  id            String      @id @default(cuid())
  enrollmentId  String
  chapterItemId String
  completedAt   DateTime    @default(now())
  chapterItem   ChapterItem @relation(fields: [chapterItemId], references: [id], onDelete: Cascade)
  enrollment    Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, chapterItemId])
}

model QuizAttempt {
  id           String          @id @default(cuid())
  userId       String
  quizId       String
  enrollmentId String?
  scorePercent Int?
  passed       Boolean?
  answers      Json?
  submittedAt  DateTime        @default(now())
  finalGrade   FinalQuizGrade?
  enrollment   Enrollment?     @relation(fields: [enrollmentId], references: [id])
  quiz         Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinalQuizGrade {
  id           String      @id @default(cuid())
  attemptId    String      @unique
  enrollmentId String
  gradeOver20  Int
  mention      String?
  gradedById   String
  gradedAt     DateTime    @default(now())
  comment      String?
  attempt      QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  grader       User        @relation("Grader", fields: [gradedById], references: [id], onDelete: Cascade)
}

model Certificate {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  userId       String
  moduleId     String
  finalGrade   Int
  mention      String
  issuedAt     DateTime   @default(now())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Discussion {
  id        String       @id @default(cuid())
  moduleId  String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime     @default(now())
  module    Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  parent    Discussion?  @relation("DiscussionReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Discussion[] @relation("DiscussionReplies")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}
