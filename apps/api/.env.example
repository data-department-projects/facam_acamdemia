# FACAM ACADEMIA — API (Railway / production)
# Copier en .env et renseigner. Sur Railway, définir ces variables dans le dashboard.

# ─── Base de données (obligatoire)
# Supabase : Project Settings > Database > Connection string (URI)
# Pooler (port 6543) pour l’app, avec pgbouncer=true
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Connexion directe (port 5432) pour les migrations Prisma
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ─── JWT (obligatoire en production)
JWT_SECRET="votre-secret-long-et-imprevisible-min-32-caracteres"
# Optionnel
JWT_EXPIRES_IN="7d"

# ─── Serveur (Railway définit PORT automatiquement)
PORT=3001
HOST="0.0.0.0"

# ─── CORS (origines autorisées pour le frontend)
# Ex. frontend Vercel : https://ton-app.vercel.app
# Plusieurs origines : https://app1.com,https://app2.com
CORS_ORIGIN="*"

# ─── Emails (OTP réinitialisation mot de passe)
# Gmail : utiliser un mot de passe d’application (voir CONFIGURATION.md)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
EMAIL_FROM_NAME="FACAM ACADEMIA"
APP_LOGO_URL=""
