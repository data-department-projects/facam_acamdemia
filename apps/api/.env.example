# FACAM ACADEMIA — API (Railway, local, etc.)
# Copier vers .env et remplacer les valeurs marquées CHANGER par tes secrets réels.

# ---------------------------------------------------------------------------
# Environnement
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ---------------------------------------------------------------------------
# CORS (frontend Vercel)
# En prod : URL de ton front Vercel (et domaine custom), séparées par des virgules.
# Exemple : CORS_ORIGIN=https://facam-academia.vercel.app,https://www.facam-academia.com
# ---------------------------------------------------------------------------
CORS_ORIGIN=

# ---------------------------------------------------------------------------
# PostgreSQL (Prisma).
# Supabase : deux URLs — pooler (port 6543) pour le runtime, direct (port 5432) pour les migrations.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.CHANGER_PROJECT_REF:CHANGER_MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.CHANGER_PROJECT_REF:CHANGER_MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Local sans Supabase :
# DATABASE_URL=postgresql://facam:facam@localhost:5432/facam_academia?schema=public
# DIRECT_URL=postgresql://facam:facam@localhost:5432/facam_academia?schema=public

# ---------------------------------------------------------------------------
# JWT (bearer). Secret long et aléatoire, jamais celui d'exemple en production.
# Générer : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGER_remplacer_par_un_secret_long_et_aleatoire_minimum_32_caracteres
JWT_ACCESS_EXPIRES_IN=15m

# ---------------------------------------------------------------------------
# Refresh cookie httpOnly (facam_refresh)
# Local : lax  |  Prod front Vercel + API Railway (domaines différents) : none
# ---------------------------------------------------------------------------
REFRESH_TOKEN_DAYS=30
AUTH_REFRESH_SAMESITE=lax

# ---------------------------------------------------------------------------
# Supabase Storage (service role)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://CHANGER_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGER_SERVICE_ROLE_KEY

# ---------------------------------------------------------------------------
# Certificats PDF — assets sur Railway
# Si apps/api/assets/attestation-template.jpeg est commité dans le dépôt, laisser vide.
# Sinon, renseigner le chemin absolu vers les fichiers sur le serveur Railway.
# ---------------------------------------------------------------------------
CERTIFICATE_TEMPLATE_PATH=
CERTIFICATE_SIGNATURE_PATH=

# ---------------------------------------------------------------------------
# Email OTP (SMTP). Si non utilisé, laisser SMTP_USER/SMTP_PASS vides.
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=FACAM ACADEMIA
APP_LOGO_URL=
