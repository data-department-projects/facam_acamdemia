# FACAM ACADEMIA - Variables d'environnement (copier en .env et renseigner)

# Base de données (Prisma - API)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/FACAM_ACADEMIA?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API (backend)
API_URL=http://localhost:3001
PORT=3001
# URL de l'API pour le frontend (appels depuis le navigateur)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Resend (emails / OTP réinitialisation mot de passe)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FACAM ACADEMIA <onboarding@resend.dev>
# URL du logo pour l'email OTP (ex: https://votresite.com/logo.png)
APP_LOGO_URL=

# Upstash Redis (optionnel, cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Microsoft Graph (SharePoint - documents)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
SHAREPOINT_SITE_URL=
