# FACAM ACADEMIA - Variables d'environnement (copier en .env et renseigner)
# Ne jamais committer de vrais mots de passe ni de clés : utiliser uniquement des placeholders ici.

# Base de données Supabase (Prisma - API)
# Remplacez [YOUR-PASSWORD] par le mot de passe de votre base (Database Settings).
# Si le mot de passe contient @, #, $, etc., encodez-le en URL (ex: @ → %40, # → %23).
# Pooler (6543) : pour l'app NestJS, avec pgbouncer=true (obligatoire en mode Transaction).
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Connexion directe (pour migrations Prisma) : host db.[PROJECT_REF].supabase.co, port 5432.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase
# URL projet (côté serveur API : SUPABASE_URL ou NEXT_PUBLIC_SUPABASE_URL pour Storage avatars)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
# Clé « service_role » : tableau Supabase > Settings > API (ne pas exposer au frontend).
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SUPABASE_SERVICE_ROLE_KEY]

# API (backend)
API_URL=http://localhost:3001
PORT=3001
# URL de l'API pour le frontend (appels depuis le navigateur)
NEXT_PUBLIC_API_URL=http://localhost:3001
